# /etc/ndb/ndb.env  — shared environment for all three nDB services.
# Copy to /etc/ndb/ndb.env, fill in, then `chmod 600 /etc/ndb/ndb.env`.

# ---- auth: shared bearer token gating /v1 and POST /mcp ----
# Generate one:  openssl rand -hex 32
# Every developer/agent sends:  Authorization: Bearer <this>
NDB_TOKEN=replace-with-openssl-rand-hex-32

# ---- TLS (edge) ----
NDB_EDGE_BIND=0.0.0.0:443
NDB_TLS_CERT=/etc/ndb/fullchain.pem
NDB_TLS_KEY=/etc/ndb/privkey.pem

# ---- upstream wiring (edge -> localhost services) ----
NDB_DATA_UPSTREAM=127.0.0.1:8742
NDB_MCP_UPSTREAM=127.0.0.1:9000

# ---- logging ----
RUST_LOG=info

# ---- optional: per-agent capability gating for the MCP server ----
# JSON principal; gates each tool call by capability (read/iter/commit/admin...).
# Leave unset for an unrestricted (token-gated) surface.
# NDB_MCP_PRINCIPAL={"name":"alice","capabilities":["read","iter","vector_search"]}
